# Build output
/build/
# out-of-source builds (build-asan, build-ubsan, etc.)
/build-*/
*.o
*.a
*.so
*.obj
*.lib
*.exe
*.pdb

# CMake FetchContent checkouts
/JUCE/
# CI-cached JUCE/Catch2 (FETCHCONTENT_BASE_DIR)
/.deps/

# Fetched tooling (pluginval prebuilt) — run-all-checks.sh / CI re-fetch it
/tools/

# Local app data that must never be committed
*.settings
*.log

# Stale import/session artifacts
/vasynth-skeleton.zip
/VASynth-README.md

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
