{
  "name": "Novation Launchkey Mini",
  "match": ["Launchkey Mini", "Launchkey Mini MK3", "LKMK3 Mini"],
  "pitchBendRange": 2,
  "notes": "Default: the 8 rotary pots send CC 21-28. Pads/transport are not mapped here (they send notes/other CCs). Learn any control to override.",
  "mappings": [
    { "cc": 21, "param": "filter_cutoff" },
    { "cc": 22, "param": "filter_reso" },
    { "cc": 23, "param": "filter_env_amt" },
    { "cc": 24, "param": "amp_release" },
    { "cc": 25, "param": "lfo_rate" },
    { "cc": 26, "param": "lfo_depth" },
    { "cc": 27, "param": "reverb_mix" },
    { "cc": 28, "param": "delay_mix" }
  ]
}
